# ── Firebase web app config ─────────────────────────────────────────────
# From Firebase console → Project settings → Your apps → Web app → Config.
# These values identify your project to Google; they are NOT secrets, 
# your data is protected by Firestore security rules (see firestore.rules).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Access control ───────────────────────────────────────────────────────
# The ONLY email allowed to use this deployment. Must match the user you
# create in Firebase console → Authentication, and the email in firestore.rules.
VITE_ALLOWED_EMAIL=you@example.com

# ── Optional ─────────────────────────────────────────────────────────────
# Web push notifications (Firebase console → Cloud Messaging → Web Push
# certificates → key pair). Leave empty to disable push, the app works fine
# without it.
VITE_FIREBASE_VAPID_KEY=

# Run on bundled sample data with no Firebase at all (used for the public demo).
VITE_DEMO_MODE=false
