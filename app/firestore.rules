rules_version = '2';

// JobPilot single-owner rules.
//
// Replace OWNER_EMAIL@example.com with YOUR email (the same one you set in
// app/.env as VITE_ALLOWED_EMAIL), then deploy:
//
//   firebase deploy --only firestore:rules
//
// This is the real security boundary: only your signed-in account can read
// or write anything. The client-side email check is convenience, not security.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'OWNER_EMAIL@example.com';
    }
  }
}
